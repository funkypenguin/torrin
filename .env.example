# Cloudflare R2 (object storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=torrin-media
R2_PUBLIC_URL=https://stream.yourdomain.com

# Signing key (generate with: openssl rand -hex 32)
SIGNING_KEY=

# qBittorrent
QBIT_USERNAME=admin
QBIT_PASSWORD=

# VPN (gluetun - see https://github.com/qdm12/gluetun-wiki)
VPN_SERVICE_PROVIDER=airvpn
VPN_PRIVATE_KEY=
VPN_PRESHARED_KEY=

# Cloudflare Tunnel (optional, for HTTPS)
CLOUDFLARE_TUNNEL_TOKEN=

# Jackett
JACKETT_API_KEY=

# API
API_PORT=9090

COMPOSE_PROJECT_NAME=torrin
